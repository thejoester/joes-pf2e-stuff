    {
      "type": "effect",
      "name": "Effect: Sportlebore Infestation",
      "img": "modules/pf2e-kingmaker/assets/actor-portraits/bestiaries/sportlebore-swarm.webp",
      "system": {
        "tokenIcon": {
          "show": true
        },
        "duration": {
          "value": 1,
          "unit": "days",
          "sustained": false,
          "expiry": "turn-end"
        },
        "description": {
          "gm": "",
          "value": "<h2>(Generated effect from @UUID[Scene.ogTLZZN9rcabv7yC.Token.djXsq4TVTWZUmr7I.Actor.3VFHZyjSjNA1jbiO]{Sportlebore Swarm} &gt; @UUID[Scene.ogTLZZN9rcabv7yC.Token.djXsq4TVTWZUmr7I.Actor.3VFHZyjSjNA1jbiO.Item.wugLYHXdCUg05j8X]{Sportlebore Infestation})</h2>\n<p><strong>Saving Throw</strong> <a class=\"inline-check with-repost\" data-pf2-traits=\"disease\" data-pf2-repost-flavor=\"Sportlebore Infestation\" data-pf2-show-dc=\"gm\" data-pf2-label=\"Sportlebore Infestation DC\" data-pf2-check=\"fortitude\" draggable=\"true\" data-roller-role=\"target\" data-item-uuid=\"Scene.ogTLZZN9rcabv7yC.Token.djXsq4TVTWZUmr7I.Actor.3VFHZyjSjNA1jbiO.Item.wugLYHXdCUg05j8X\" data-pf2-dc=\"22\"><i class=\"fa-solid fa-heart-pulse icon\" inert></i><span class=\"label\"><span data-visibility=\"gm\">DC 22</span> Fortitude</span><i class=\"fa-solid fa-comment-alt\" data-pf2-repost title=\"Post prompt to chat\"></i></a></p>\n<p><strong>Stage 1</strong> carrier with no ill effect (1 day)</p>\n<p><strong>Stage 2</strong> <a class=\"content-link\" draggable=\"true\" data-link data-uuid=\"Compendium.pf2e.conditionitems.Item.MIRkyAjyBeXivMa7\" data-id=\"MIRkyAjyBeXivMa7\" data-type=\"Item\" data-pack=\"pf2e.conditionitems\" data-tooltip=\"Item\" data-tooltip-text=\"Condition Item\"><i class=\"fa-solid fa-face-zany\" inert></i>Enfeebled 1</a> (1 hour)</p>\n<p><strong>Stage 3</strong> <a class=\"content-link\" draggable=\"true\" data-link data-uuid=\"Compendium.pf2e.conditionitems.Item.MIRkyAjyBeXivMa7\" data-id=\"MIRkyAjyBeXivMa7\" data-type=\"Item\" data-pack=\"pf2e.conditionitems\" data-tooltip=\"Item\" data-tooltip-text=\"Condition Item\"><i class=\"fa-solid fa-face-zany\" inert></i>Enfeebled 2</a> (1 hour)</p>\n<p><strong>Stage 4</strong> <a class=\"inline-roll roll\" data-formula=\"{4d6[bludgeoning]}\" data-base-formula=\"4d6[bludgeoning]\" data-damage-roll=\"4d6[bludgeoning]\" data-traits=\"disease\" data-item-id=\"wugLYHXdCUg05j8X\" data-flavor=\"Sportlebore Infestation\"><i class=\"fa-solid fa-dice-d6\" inert></i><span>4d6 bludgeoning</span></a> damage (<a class=\"inline-check with-repost\" data-pf2-traits=\"disease\" data-pf2-roll-options=\"damaging-effect\" data-pf2-repost-flavor=\"Sportlebore Infestation\" data-pf2-show-dc=\"gm\" data-pf2-label=\"Sportlebore Infestation DC\" data-pf2-check=\"fortitude\" draggable=\"true\" data-roller-role=\"target\" data-item-uuid=\"Scene.ogTLZZN9rcabv7yC.Token.djXsq4TVTWZUmr7I.Actor.3VFHZyjSjNA1jbiO.Item.wugLYHXdCUg05j8X\" data-pf2-dc=\"25\"><i class=\"fa-solid fa-heart-pulse icon\" inert></i><span class=\"label\"><span data-visibility=\"gm\">DC 25</span> Basic Fortitude</span><i class=\"fa-solid fa-comment-alt\" data-pf2-repost title=\"Post prompt to chat\"></i></a> save) as the host painfully vomits out a sportlebore swarm and returns to stage 1</p>"
