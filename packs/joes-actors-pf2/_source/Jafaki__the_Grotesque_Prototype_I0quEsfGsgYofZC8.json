    {
      "type": "action",
      "name": "Grappling Tentacles",
      "system": {
        "actionType": {
          "value": "action"
        },
        "description": {
          "value": "<p>Jafaki lashes out at up to two creatures within 15 feet, making a separate <strong>Pseudopod Slam</strong> for each.</p><p>On a hit, Jafaki attempts a separate @Check[type:athletics|modifier:16|traits:attack|name:Grappling Tentacle] against the target’s Fortitude DC.</p><p>On a success, the target becomes @Compendium[pf2e.conditionitems.Grabbed]{Grabbed} (Escape DC 23).</p><p>Jafaki can Grapple a target he already has grabbed or restrained without having a hand free, and can maintain up to two grapples simultaneously.</p><p></p>",
          "gm": ""
        },
